# --- Telegram ---
# توکن بات که از @BotFather می‌گیری
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# آیدی کانال: یوزرنیم عمومی مثل @your_channel یا آیدی عددی کانال خصوصی مثل -1001234567890
TELEGRAM_CHANNEL_ID=@your_channel

# --- OpenRouter ---
# کلید API از openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# مدل خلاصه‌سازی. پیشنهاد برای فارسی + ارزان: google/gemini-2.5-flash
# جایگزین‌ها: google/gemini-2.0-flash-001 ، openai/gpt-4o-mini ، anthropic/claude-3.5-haiku
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- تنظیمات اختیاری ---
# حداکثر تعداد خبر در هر اجرا
MAX_POSTS_PER_RUN=3
# جستجوی وب OpenRouter (مدل را به :online تبدیل می‌کند). هزینه‌ی اضافه دارد. true/false
ENABLE_WEB_SEARCH=false
